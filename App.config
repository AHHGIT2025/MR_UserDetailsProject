<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<connectionStrings>
		<!-- Adjust Data Source to your SQL Server instance -->
		<add name="DefaultConnection"
			 connectionString="Data Source=.;Initial Catalog=HattabDB;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
			 providerName="System.Data.SqlClient" />
		
		
		
		
  </connectionStrings>
</configuration>

 

